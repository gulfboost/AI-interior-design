{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "node": "22"
  },
  "steps": {
    "install": {
      "commands": [
        { "cmd": "npm install -g pnpm", "customName": "Install pnpm" },
        { "cmd": "cd frontend && pnpm install --frozen-lockfile", "customName": "Install Node dependencies" }
      ]
    },
    "build": {
      "commands": [
        { "cmd": "cd frontend && pnpm run build", "customName": "Build Next.js app" }
      ]
    }
  },
  "deploy": {
    "startCommand": "cd /app/frontend && node_modules/.bin/next start -p ${PORT:-3000}"
  }
}
