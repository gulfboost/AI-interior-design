{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "node": "22"
  },
  "steps": {
    "build": {
      "inputs": [
        "...",
        { "local": true, "include": ["frontend"] }
      ],
      "commands": [
        "npm install -g pnpm",
        "pnpm --dir frontend install",
        "pnpm --dir frontend run build",
        "node -e \"var fs=require('fs'); var real=fs.realpathSync(process.execPath); fs.copyFileSync(real,'/app/frontend/.node'); fs.chmodSync('/app/frontend/.node',0o755);\""
      ],
      "deployOutputs": [
        { "include": ["frontend"] }
      ]
    }
  },
  "deploy": {
    "startCommand": "cd /app/frontend && /app/frontend/.node node_modules/next/dist/bin/next start -p ${PORT:-3000} -H 0.0.0.0"
  }
}
