{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "node": "22"
  },
  "steps": {
    "build": {
      "inputs": [
        "...",
        { "local": true, "include": ["frontend"] }
      ],
      "commands": [
        "npm install -g pnpm",
        "pnpm --dir frontend install --frozen-lockfile",
        "pnpm --dir frontend run build"
      ],
      "deployOutputs": [
        { "include": ["frontend"] }
      ]
    }
  },
  "deploy": {
    "startCommand": "node /app/frontend/node_modules/next/dist/bin/next.js start -p ${PORT:-3000}"
  }
}
