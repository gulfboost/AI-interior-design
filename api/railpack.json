{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "python": "3.11",
    "uv": "latest"
  },
  "steps": {
    "install": {
      "inputs": [
        "...",
        { "local": true, "include": ["."] }
      ],
      "commands": [
        "uv --directory api sync --no-dev",
        "cp -r api/.venv/lib/python3.11/site-packages /app/api/site-packages"
      ],
      "deployOutputs": [
        { "include": ["api/app"] },
        { "include": ["api/site-packages"] }
      ]
    }
  },
  "deploy": {
    "startCommand": "PYTHONPATH=/app/api/site-packages:/app/api python3.11 -m uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"
  }
}
