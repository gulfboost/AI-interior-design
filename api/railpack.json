{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "python": "3.11"
  },
  "steps": {
    "install": {
      "commands": [
        "pip install uv",
        "cd api && uv sync --no-dev"
      ]
    }
  },
  "deploy": {
    "startCommand": "cd /app/api && .venv/bin/uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"
  }
}
