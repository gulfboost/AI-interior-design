{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "python": "3.11",
    "uv": "latest"
  },
  "steps": {
    "install": {
      "commands": [
        "uv sync --no-dev"
      ]
    }
  },
  "deploy": {
    "startCommand": ".venv/bin/uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"
  }
}
